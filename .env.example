# Saras environment variables.
# Copy to .env.local for local development with `vercel dev` (gitignored).

# Anthropic API key — used SERVER-SIDE only by api/spec.ts to generate
# visualization specs. Never expose this to the browser / never prefix with VITE_.
# Get one at https://console.anthropic.com/ and set the same value in the Vercel
# project (Settings → Environment Variables) for deployed environments.
ANTHROPIC_API_KEY=
